{
  "name": "recursive-kanban-planner",
  "private": true,
  "type": "module",
  "scripts": {
    "build:css": "tailwindcss -c ./tailwind.config.js -i ./src/interface/tailwind.css -o ./assets/app.css",
    "watch:css": "tailwindcss -c ./tailwind.config.js -i ./src/interface/tailwind.css -o ./assets/app.css --watch",
    "check:css": "node ./scripts/check-css.mjs",
    "smoke": "npm run check:css && playwright test",
    "smoke:headed": "npm run check:css && playwright test --headed"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "tailwindcss": "^3.4.17"
  }
}
